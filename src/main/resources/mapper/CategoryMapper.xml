<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubbles.server.mapper.CategoryMapper">

    <sql id="baseColumns">
        category_id, name, description, parent_id, sort_order, icon_url, color, create_time
    </sql>

    <resultMap id="CategoryResultMap" type="com.bubbles.pojo.entity.Category">
        <id column="category_id" property="categoryId" />
        <result column="name" property="name" />
        <result column="description" property="description" />
        <result column="parent_id" property="parentId" />
        <result column="sort_order" property="sortOrder" />
        <result column="icon_url" property="iconUrl" />
        <result column="color" property="color" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <select id="findAll" resultMap="CategoryResultMap">
        SELECT <include refid="baseColumns"/>
        FROM categories
        ORDER BY create_time DESC
    </select>

    <select id="findById" resultMap="CategoryResultMap">
        SELECT <include refid="baseColumns"/>
        FROM categories
        WHERE category_id = #{categoryId}
    </select>

    <select id="findByName" resultMap="CategoryResultMap">
        SELECT <include refid="baseColumns"/>
        FROM categories
        WHERE name = #{name}
    </select>

    <select id="findByRole" resultMap="CategoryResultMap">
        SELECT <include refid="baseColumns"/>
        FROM categories
        <where>
            <choose>
                <when test="role == 'ADMIN'">
                    <!-- 管理员可以看到所有分类 -->
                </when>
                <otherwise>
                    <!-- 普通用户只看到启用的分类 -->
                    AND status = 'ACTIVE'
                </otherwise>
            </choose>
        </where>
        ORDER BY create_time DESC
    </select>

    

</mapper>
